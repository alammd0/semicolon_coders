generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// this is User model
model User {
  id         Int        @id @default(autoincrement())
  firstName  String
  lastName   String?
  email      String     @unique
  password   String?
  otp        String?
  expiresAt  DateTime?
  role       Role       @default(user)
  isVerified Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum Role {
  user
  admin
}
